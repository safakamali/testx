"contentType":"article","subtype":"news","lastUpdated":1777540067765,"firstUpdated":1777540067765,"topics":["World"]},"tags":[],"description":"Pro-Palestinian activists say 22 boats carrying aid for Gaza were illegally intercepted in international waters near the Greek island.","image":{"type":"indexImage","model":{"blocks":{"src":"https://ichef.bbci.co.uk/news/480/cpsprodpb/ef63/live/b4c1f7c0-4471-11f1-ac78-2112837ce2aa.jpg","altText":"Activists put up their hands on board a Gaza-bound aid flotilla vessel intercepted by the Israeli navy near the Greek island of Crete (30 April 2026)","width":1227,"height":689}}},"relatedUrls":[],"id":"urn:bbc:optimo:asset:c4g4lk9m77vo","brandName":"","seriesName":"","seriesId":"","brandId":"","versionId":""}],"collectionId":"news-home-top-stories-intl-tipo","sectionTitleProps":{"link":"https://www.bbc.com/news","linkType":"internal"},"paginationData":{"page":0,"pageSize":7,"total":8},"title":"More news","summary":"","disableAutoPlay":false,"innerCollections":[],"playlistMode":false},{"type":"texas","content":[{"title":"The King and Queen in the Big Apple: What the royals did on their third day in the US","href":"/news/videos/ce9pj2ygmkno","isLiveNow":false,"metadata":{"contentType":"video","subtype":"clip news","lastUpdated":1777509465889,"firstUpdated":1777509465889,"topics":["US \u0026 Canada"]},"tags":[],"description":"After visiting the 9/11 Memorial, Queen Camilla read to children at the New York Public Library and King Charles visited a community organisation in Harlem.","image":{"type":"indexImage","model":{"blocks":{"src":"https://ichef.bbci.co.uk/news/480/cpsprodpb/3803/live/25879b90-442c-11f1-bd52-e755d604ece4.jpg","altText":"Splitscreen. Left, Camilla reads a book to kids. Right, Charles and a small child plant vegetables with a trowel. ","width":1920,"height":1080}}},"relatedUrls":[],"id":"urn:bbc:optimo:asset:ce9pj2ygmkno","brandName":"","seriesName":"","seriesId":"","brandId":"","versionId":""},{"title":"Chris Hemsworth's deeply emotional journey with his father","href":"/reel/video/p0myl6m3/watch","isLiveNow":false,"metadata":{"contentType":"video","subtype":"reels","lastUpdated":1777525200000,"firstUpdated":1777525200000,"topics":["Film \u0026 TV"]},"tags":[],"description":"Chris Hemsworth tells Graham Norton how he made a documentary about his dad's Alzheimer's treatment.","image":{"type":"indexImage","model":{"blocks":{"src":"https://ichef.bbci.co.uk/images/ic/1920xn/p0mylgmh.jpg","altText":"Chris Hemsworth's deeply emotional journey across Australia with his father","width":1920,"height":1080,"duration":256}}},"relatedUrls":[],"id":"urn:pubpipe:gnlvideoproject:video:p0myl6m3","brandName":"","seriesName":"","seriesId":"","brandId":"","versionId":""},{"title":"Aerial video shows destruction after tornado strikes small Texas town","href":"/news/videos/cvgzlpzglx2o","isLiveNow":false,"metadata":{"contentType":"video","subtype":"clip news","lastUpdated":1777510583602,"firstUpdated":1777510583602,"topics":["US \u0026 Canada"]},"tags":[],"description":"A severe storm outbreak has been battering parts of the Midwest and Southern United States for nearly a week. ","image":{"type":"indexImage","model":{"blocks":{"src":"https://ichef.bbci.co.uk/news/480/cpsprodpb/1258/live/9eb8eda0-442e-11f1-b55d-0f258dce1735.jpg","altText":"Mineral Wells, Texas, lies destroyed in a drone shot post-tornado.","width":1920,"height":1080}}},"relatedUrls":[],"id":"urn:bbc:optimo:asset:cvgzlpzglx2o","brandName":"","seriesName":"","seriesId":"","brandId":"","versionId":""},{"title":"Joy as Kenya's record-breaking runner Sabastian Sawe returns home","href":"/news/videos/cglpkexdye1o","isLiveNow":false,"metadata":{"contentType":"video","subtype":"clip news","lastUpdated":1777514597952,"firstUpdated":1777514597952,"topics":["Africa"]},"tags":[],"description":"BBC reports from Kenya, home to Sabastian Sawe, the first man to run a marathon in under two hours.","image":{"type":"indexImage","model":{"blocks":{"src