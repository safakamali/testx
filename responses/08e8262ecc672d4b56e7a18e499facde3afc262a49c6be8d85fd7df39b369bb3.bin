":{"type":"indexImage","model":{"blocks":{"src":"https://ichef.bbci.co.uk/images/ic/1920xn/p0nh13f8.jpg","altText":"Classic Ford Customline automobile displayed outside a motel in Springfield, Missouri (Credit: Serenity Strull/ Getty Images)","width":3745,"height":2107}}},"relatedUrls":[],"id":"urn:pubpipe:wwverticals:article:travel/article/20260428-springfield-the-beloved-birthplace-of-route-66","brandName":"","seriesName":"","seriesId":"","brandId":"","versionId":""}],"collectionId":"8c812c30-6c8f-4cd9-af39-583337188e9d","sectionTitleProps":{"link":"https://www.bbc.com/travel","linkType":"internal"},"paginationData":{"page":0,"pageSize":1,"total":50},"title":"Travel","summary":"","disableAutoPlay":false,"innerCollections":[],"playlistMode":false},{"type":"advertisement","model":{"adType":"horizontal"},"incrementedType":"mid_4"},{"type":"wyoming","content":[],"collectionId":"","sectionTitleProps":{},"paginationData":{"page":0,"pageSize":0,"total":0},"title":"","summary":"","disableAutoPlay":false,"innerCollections":[{"title":"US \u0026 Canada News","data":[{"title":"'Once in a lifetime opportunity' - Kansas City readies for World Cup influx","href":"/news/articles/czredkdyykdo","isLiveNow":false,"metadata":{"contentType":"article","subtype":"news","lastUpdated":1777542581802,"firstUpdated":1777542581802,"topics":["US \u0026 Canada"]},"tags":[],"description":"Officials see this summer's football tournament as a chance to show off the city to the world - but some locals have concerns.\n","image":{"type":"indexImage","model":{"blocks":{"src":"https://ichef.bbci.co.uk/news/480/cpsprodpb/b5b4/live/cca8bf50-4303-11f1-bd52-e755d604ece4.jpg","altText":"Fans dressed in USA shirts and with USA flags cheer with arms aloft","width":976,"height":651}}},"relatedUrls":[],"id":"urn:bbc:optimo:asset:czredkdyykdo","brandName":"","seriesName":"","seriesId":"","brandId":"","versionId":""},{"title":"US singer D4vd bought tools online to dispose of girl's body, prosecutors allege","href