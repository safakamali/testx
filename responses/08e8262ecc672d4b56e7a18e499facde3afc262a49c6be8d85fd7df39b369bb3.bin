.0-4/grey-placeholder.png" class="sc-5340b511-0 gUePlo hide-when-no-script" aria-label="image unavailable"/><img sizes="25vw" srcSet="https://ichef.bbci.co.uk/images/ic/160x90/p0ng00t1.jpg.webp 160w, https://ichef.bbci.co.uk/images/ic/240x135/p0ng00t1.jpg.webp 240w, https://ichef.bbci.co.uk/images/ic/320x180/p0ng00t1.jpg.webp 320w, https://ichef.bbci.co.uk/images/ic/480x270/p0ng00t1.jpg.webp 480w, https://ichef.bbci.co.uk/images/ic/640x360/p0ng00t1.jpg.webp 640w, https://ichef.bbci.co.uk/images/ic/800x450/p0ng00t1.jpg.webp 800w, https://ichef.bbci.co.uk/images/ic/1024x576/p0ng00t1.jpg.webp 1024w, https://ichef.bbci.co.uk/images/ic/1376x774/p0ng00t1.jpg.webp 1376w, https://ichef.bbci.co.uk/images/ic/1920x1080/p0ng00t1.jpg.webp 1920w" src="https://ichef.bbci.co.uk/images/ic/480x270/p0ng00t1.jpg.webp" loading="lazy" alt="Is there any proof that scrolling ruins our attention span?" class="sc-5340b511-0 hLdNfA"/></div><div data-testid="content-type-label" class="sc-3430e63c-0 cWNIvw"><div data-testid="content-type-icon-wrapper" class="sc-3430e63c-1 dfChTY"><svg viewBox="0 0 32 32" width="30" height="30" category="playback-avkx" icon="play" type="playback-avkx:play" class="sc-583246d7-0 jUqtCV"><path d="M29 16 5.8 1v30L29 16z"></path></svg></div></div></div></div><div data-testid="card-text-wrapper" class="sc-fa53feb6-0 hnNPal"><div class="sc-feaf8701-1 dzYnRP"><div class="sc-feaf8701-0 ktNWyK"><h2 data-testid="card-headline" class="sc-feaf8701-3 eQumHa">Is there any proof that scrolling ruins our attention span?</h2></div></div><p data-testid="card-description" class="sc-329e5f2b-0 ffnHHm">Journalist Joss Fong joins Katty to discuss whether phones, social media, and algorithms are really making our attention spans worse.</p></div></div></a></div></div><div data-testid="dundee-card" data-indexcard="true" class="sc-225578b-0 ezQaGx"><div data-testid="anchor-inner-wrapper"><a href="/reel/video/p0ndkvbw/watch" data-testid="internal-link" class="sc-8a623a54-0 huZCWi"><div dat