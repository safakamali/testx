5.8955 24.4686 26.616 23.4655C27.4213 22.3352 28.2972 20.4986 28.6787 19.0999C29.1167 17.4611 29.1167 14.0986 28.6787 12.4597C28.0288 10.0721 26.7573 7.96702 24.963 6.22927C23.6774 5.01426 22.9003 4.4774 21.3745 3.75687C19.3683 2.81029 18.3087 2.59837 15.7939 2.59837C13.2791 2.59837 12.2195 2.81029 10.2134 3.75687C8.68753 4.4774 7.91049 5.01426 6.62484 6.22927C4.83058 7.96702 3.57318 10.0721 2.90916 12.488C2.4712 14.0703 2.4712 17.4893 2.90916 19.0717C3.57318 21.4876 4.83058 23.5926 6.62484 25.3304C8.15067 26.7856 9.35155 27.5344 11.386 28.2973C13.5193 29.1026 16.7829 29.258 19.0858 28.6505Z"></path><path id="inner" d="M13.8318 24.0437C10.5541 23.2949 7.94042 20.6671 7.24815 17.3894C6.42872 13.5042 8.40665 9.57661 12.0658 7.83886C16.2901 5.84681 21.4327 7.72584 23.4389 12.0066C25.6287 16.683 23.1422 22.2918 18.1974 23.8459C16.9965 24.2274 15.0186 24.3122 13.8318 24.0437Z"></path></svg><span class="sc-feaf8701-4 cHaohn">LIVE</span></div><h2 data-testid="card-headline" class="sc-feaf8701-3 efpPCS">Mother of Jewish stabbing victim tells BBC she&#x27;s &#x27;horrified these things could happen on London&#x27;s streets&#x27;</h2></div></div></a></div><p data-testid="card-description" class="sc-d8331fdf-0 gXKxOi">The mother of Shloime Rand, 34, says she hopes her son will be home from hospital for Shabbat on Friday. The other victim has been named as Moshe Shine, 76.</p><div class="sc-1907e52a-0 jkvOKk"></div></div></div><hr class="sc-d8331fdf-7 erbNwH"/></div></div></div><div class="sc-82b3c53b-0 iesBTl"><div class="sc-cd6075cf-0 iVRcOH"><div class="sc-82b3c53b-0 hhIpVe"><div data-testid="dundee-card" data-indexcard="true" class="sc-225578b-0 ezQaGx"><div data-testid="anchor-inner-wrapper"><a href="/news/articles/cx21m88rd14o" data-testid="internal-link" class="sc-8a623a54-0 huZCWi"><div data-testid="dundee-article" class="sc-329e5f2b-1 gnGpEW"><div data-testid="card-image-wrapper" class="sc-329e5f2b-3 kkqTyl"><div data-testid="card-media" class="sc-329e5f2b-4 eASWcB"><div class="sc-5340b511-1 cMIbKV"><img src="https://static.files.bbci.co.uk/bbcdotcom/web/20260427-074339-4d487e3684-web-3.2.0-4/grey-placeholder.png" class="sc-5340b511-0 gUePlo hide-when-no-script" aria-label="image unavailable"/><img sizes="25vw" srcSet="https://ichef.bbci.co.uk/news/240/cpsprodpb/f095/live/e9ca4ae0-442a-11f1-84a0-55946b952877.jpg.webp 240w,https://ichef.bbci.co.uk/news/320/cpsprodpb/f095/live/e9ca4ae0-442a-11f1-84a0-55946b952877.jpg.webp 320w,https://ichef.bbci.co.uk/news/480/cpsprodpb/f095/live/e9ca4ae0-442a-11f1-84a0-55946b952877.jpg.webp 480w,https://ichef.bbci.co.uk/news/640/cpsprodpb/f095/live/e9ca4ae0-442a-11f1-84a0-55946b952877.jpg.webp 640w,https://ichef.bbci.co.uk/news/800/cpsprodpb/f095/live/e9ca4ae0-442a-11f1-84a0-55946b952877.jpg.webp 800w,https://ichef.bbci.co.uk/news/1024/cpsprodpb/f095/live/e9ca4ae0-442a-11f1-84a0-55946b952877.jpg.webp 1024w,https://ichef.bbci.co.uk/news/1536/cpsprodpb/f095/live/e9ca4ae0-442a-11f1-84a0-55946b952877.jpg.webp 1536w" src="https://ichef.bbci.co.uk/news/480/cpsprodpb/f095/live/e9ca4ae0-442a-11f1-84a0-55946b952877.jpg.webp" loading="eager" alt="A female petrol station attendant refuels a white car" class="sc-5340b511-0 hLdNfA"/></div></div></div><div data-testid="card-text-wrapper" class="sc-fa53feb6-0 hnNPal"><div class="sc-feaf8701-1 dzYnRP"><div class="sc-feaf8701-0 ktNWyK"><h2 data-testid="card-headline" class="sc-feaf8701-3 eQumHa">Oil price hits highest since 2022 after report Trump to be briefed on new Iran options</h2></div></div><p data-testid="card-description" class="sc-329e5f2b-0 ffnHHm">Axios reported that US Central Command has prepared a plan for a wave of &quot;short and powerful&quot; strikes on Iran.</p><div class="sc-1907e52a-0 jkvOKk"><span data-testid="card-metadata-lastupdated" class="sc-1907e52a-1 bZuSaP">22 mins ago</span><div data-testid="card-metadata-separator" class="sc-1907e52a-3 hCbeEG"></div><span data-testid="card-metadata-tag" class="sc-1907e52a-2 dIrLFx">Business</span></div></div></div></a></div></div></div><div class="sc-82b3c53b-0 hhIpVe"><div data-testid="dundee-card" data-indexcard="true" class="sc-225578b-0 ezQaGx"><div data-testid="anchor-inner-wrapper"><a href="/news/videos/c5y9wdprpyyo" data-testid="internal-link" class="sc-8a623a54-0 huZCWi"><div data-testid="dundee-video" class="sc-329e5f2b-1 iXOorM"><div data-testid="card-image-wrapper" class="sc-329e5f2b-3 kkqTyl"><div data-testid="card-media" class="sc-329e5f2b-4 eASWcB"><div class="sc-5340b511-1 cMIbKV"><img src="https://static.files.bbci.co.uk/bbcdotcom/web/20260427-074339-4d487e3684-web-3.2.0-4/grey-placeholder.png" class="sc-5340b511-0 gUePlo hide-when-no-script" aria-label="image unavailable"/><img sizes="25vw" srcSet="https://ichef.bbci.co.uk/news/240/cpsprodpb/0976/live/9ae859a0-445a-11f1-bd52-e755d604ece4.jpg.webp 240w,https://ichef.bbci.co.uk/news/320/cpsprodpb/0976/live/9ae859a0-445a-11f1-bd52-e755d604ece4.jpg.webp 320w,https://ichef.bbci.co.uk/news/480/cpsprodpb/0976/live/9ae859a0-445a-11f1-bd52-e755d604ece4.jpg.webp 480w,https://ichef.bbci.co.uk/news/640/cpsprodpb/0976/live/9ae859a0-445a-11f1-bd52-e755d604ece4.jpg.webp 640w,https://ichef.bbci.co.uk/news/800/cpsprodpb/0976/live/9ae859a0-445a-11f1-bd52-e755d604ece4.jpg.webp 800w,https://ichef.bbci.co.uk/news/1024/cpsprodpb/0976/live/9ae859a0-445a-11f1-bd52-e755d604ece4.jpg.webp 1024w,https://ichef.bbci.co.uk/news/1536/cpsprodpb/0976/live/9ae859a0-445a-11f1-bd52-e755d604ece4.jpg.webp 1536w" src="https://ichef.bbci.co.uk/news/480/cpsprodpb/0976/live/9ae859a0-445a-11f1-bd52-e755d604ece4.jpg.webp" loading="eager" alt="Soldier putting missile in tube" class="sc-5340b511-0 hLdNfA"/></div><div data-testid="content-type-label" class="sc-3430e63c-0 cWNIvw"><div data-testid="content-type-icon-wrapper" class="sc-3430e63c-1 dfChTY"><svg viewBox="0 0 32 32" width="30" height="30" category="playback-avkx" icon="play" type="playback-avkx:play" class="sc-583246d7-0 jUqtCV"><path d="M29 16 5.8 1v30L29 16z"></path></svg></div></div></div></div><div data-testid="card-text-wrapper" class="sc-fa53feb6-0 hnNPal"><div class="sc-feaf8701-1 dzYnRP"><div class="sc-feaf8701-0 ktNWyK"><h2 data-testid="card-headline" class="sc-feaf8701-3 eQumHa">&#x27;Attacked 28 times in a day&#x27;: BBC visits heavily targeted US-UK base in Iraq</h2></div></div><p data-testid="card-description" class="sc-329e5f2b-0 ffnHHm">Before the fragile ceasefire in the region, this was one of the most heavily targeted US and UK military bases in the Middle East.</p><div class="sc-1907e52a-0 jkvOKk"><span data-testid="card-metadata-lastupdated" class="sc-1907e52a-1 bZuSaP">9 hrs ago</span><div data-testid="card-metadata-separator" class="sc-1907e52a-3 hCbeEG"></div><span data-testid="card-metadata-tag" class="sc-1907e52a-2 dIrLFx">US &amp; Canada</span></div></div></div></a></div></div></div></div></div><div class="sc-82b3c53b-0 WDSOi"><div class="sc-cd6075cf-0 kQGyPU"><div class="sc-82b3c53b-0 idfxvz"><div data-testid="manchester-card" data-indexcard="true" class="sc-225578b-0 ezQaGx"><div data-testid="anchor-inner-wrapper"><a href="/news/articles/cvgzd1yp2n6o" data-testid="internal-link" class="sc-8a623a54-0 huZCWi"><div data-testid="manchester-article" class="sc-548b08f-1 kDRaBB"><div data-testid="card-text-wrapper" class="sc-548b08f-2 hvtsmL"><div class="sc-feaf8701-1 dzYnRP"><div class="sc-feaf8701-0 ktNWyK"><h2 data-testid="card-headline" class="sc-feaf8701-3 eQumHa">Police say they believe abducted child was murdered as body found in Outback</h2></div></div><p data-testid="card-description" class="sc-548b08f-0 cValTX">The five-year-old girl was last seen on Saturday at an Aboriginal town camp near Alice Springs. </p><div class="sc-1907e52a-0 jkvOKk"><span data-testid="card-metadata-lastupdated" class="sc-1907e52a-1 bZuSaP">4 hrs ago</span><div data-testid="card-metadata-separator" class="sc-1907e52a-3 hCbeEG"></div><span data-testid="card-metadata-tag" class="sc-1907e52a-2 dIrLFx">Australia</span></div></div></div></a></div></div></div><div class="sc-82b3c53b-0 gSbSTK"><div data-testid="manchester-card" data-indexcard="true" class="sc-225578b-0 ezQaGx"><div data-testid="anchor-inner-wrapper"><a href="/news/articles/cyv1zdey7pmo" data-testid="internal-link" class="sc-8a623a54-0 huZCWi"><div data-testid="manchester-article" class="sc-548b08f-1 kDRaBB"><div data-testid="card-text-wrapper" class="sc-548b08f-2 hvtsmL"><div class="sc-feaf8701-1 dzYnRP"><div class="sc-feaf8701-0 ktNWyK"><h2 data-testid="card-headline" class="sc-feaf8701-3 eQumHa">The &#x27;Polar Bear Capital&#x27; with Arctic gateway ambitions</h2></div></div><p data-testid="card-description" class="sc-548b08f-0 cValTX">Canada is weighing whether a year-round northern trade route to Europe from Churchill, Manitoba, is viable, as climate change speeds Arctic warming.</p><div class="sc-1907e52a-0 jkvOKk"><span data-testid="card-metadata-lastupdated" class="sc-1907e52a-1 bZuSaP">11 hrs ago</span><div data-testid="card-metadata-separator" class="sc-1907e52a-3 hCbeEG"></div><span data-testid="card-metadata-tag" class="sc-1907e52a-2 dIrLFx">US &amp; Canada</span></div></div></div></a></div></div></div><div class="sc-82b3c53b-0 idfxvz"><div data-testid="manchester-card" data-indexcard="true" class="sc-225578b-0 ezQaGx"><div data-testid="anchor-inner-wrapper"><a href="/news/articles/cqxpr404053o" data-testid="internal-link" class="sc-8a623a54-0 huZCWi"><div data-testid="manchester-article" class="sc-548b08f-1 kDRaBB"><div data-testid="card-text-wrapper" class="sc-548b08f-2 hvtsmL"><div class="sc-feaf8701-1 dzYnRP"><div class="sc-feaf8701-0 ktNWyK"><h2 data-testid="card-headline" class="sc-feaf8701-3 eQumHa">Have the royals got their mojo back from US visit?</h2></div></div><p data-testid="card-description" class="sc-548b08f-0 cValTX">Many commentators, even critics of the monarchy, seem delighted at the spectacle. </p><div class="sc-1907e52a-0 jkvOKk"><span data-testid="card-metadata-lastupdated" class="sc-1907e52a-1 bZuSaP">7 hrs ago</span><div data-testid="card-metadata-separator" class="sc-1907e52a-3 hCbeEG"></div><span data-testid="card-metadata-tag" class="sc-1907e52a-2 dIrLFx">UK</span></div></div></div></a></div></div></div><div class="sc-82b3c53b-0 gSbSTK"><div data-testid="manchester-card" data-indexcard="true" class="sc-225578b-0 ezQaGx"><div data-testid="anchor-inner-wrapper"><a href="/news/articles/ce8pd1kr387o" data-testid="internal-link" class="sc-8a623a54-0 huZCWi"><div data-testid="manchester-article" class="sc-548b08f-1 kDRaBB"><div data-testid="card-text-wrapper" class="sc-548b08f-2 hvtsmL"><div class="sc-feaf8701-1 dzYnRP"><div class="sc-feaf8701-0 ktNWyK"><h2 data-testid="card-headline" class="sc-feaf8701-3 eQumHa">Smiles and wonder: How the US reacted to King Charles </h2></div></div><p data-testid="card-description" class="sc-548b08f-0 cValTX">A divided US has come together to watch King Charles&#x27; visit with a mix of awe, delight and hope. </p><div class="sc-1907e52a-0 jkvOKk"><span data-testid="card-metadata-lastupdated" class="sc-1907e52a-1 bZuSaP">13 hrs ago</span><div data-testid="card-metadata-separator" class="sc-1907e52a-3 hCbeEG"></div><span data-testid="card-metadata-tag" class="sc-1907e52a-2 dIrLFx">US &amp; Canada</span></div></div></div></a></div></div></div></div></div></div></section></section><div data-testid="ad-unit" data-component="ad-slot" class="sc-66bf5539-0 honDdn"><div data-testid="dotcom-mid_1" id="dotcom-mid_1" class="dotcom-ad"></div></div><section data-testid="indiana-section-outer" data-analytics-group="true" data-analytics_group_type="indiana-2" data-analytics_group_position="3" data-analytics_group_item_count="2" data-analytics_group_name="Only from the BBC" class="sc-137e23a3-1 kBGGOJ"><div data-testid="indiana-section" class="sc-137e23a3-2 bHibBM"><div class="sc-93f35dd3-2 kDYKbZ"><div class="sc-93f35dd3-1 jFZiaU"><hr data-testid="indiana-line" class="sc-93f35dd3-0 eUbJxU"/></div><div data-testid="section-title-wrapper" class="sc-93f35dd3-3 boOqBM"><div><h2 data-testid="indiana-title" class="sc-93f35dd3-4 cPmpei">Only from the BBC</h2></div></div></div><div data-testid="indiana-grid-2" class="sc-e072bc6b-0 dyMYaI"><div data-testid="edinburgh-card" data-indexcard="true" class="sc-225578b-0 ezQaGx"><div data-testid="anchor-inner-wrapper"><a href="/future/article/20260429-finding-hidden-sperm-new-technology-offers-hope-to-men-previously-told-they-were-infertile" data-testid="internal-link" class="sc-8a623a54-0 huZCWi"><div data-testid="edinburgh-article" class="sc-8a86ca4a-0 bgPRHC"><div data-testid="card-media-wrapper" class="sc-8a86ca4a-1 cazend"><div data-testid="card-media" class="sc-8a86ca4a-2 bWlUxl"><div class="sc-5340b511-1 cMIbKV"><img src="https://static.files.bbci.co.uk/bbcdotcom/web/20260427-074339-4d487e3684-web-3.2.0-4/grey-placeholder.png" class="sc-5340b511-0 gUePlo hide-when-no-script" aria-label="image unavailable"/><img sizes="(min-width: 600px) 50vw, 100vw" srcSet="https://ichef.bbci.co.uk/images/ic/160x90/p0nh9j4l.jpg.webp 160w, https://ichef.bbci.co.uk/images/ic/240x135/p0nh9j4l.jpg.webp 240w, https://ichef.bbci.co.uk/images/ic/320x180/p0nh9j4l.jpg.webp 320w, https://ichef.bbci.co.uk/images/ic/480x270/p0nh9j4l.jpg.webp 480w, https://ichef.bbci.co.uk/images/ic/640x360/p0nh9j4l.jpg.webp 640w, https://ichef.bbci.co.uk/images/ic/800x450/p0nh9j4l.jpg.webp 800w, https://ichef.bbci.co.uk/images/ic/1024x576/p0nh9j4l.jpg.webp 1024w, https://ichef.bbci.co.uk/images/ic/1376x774/p0nh9j4l.jpg.webp 1376w, https://ichef.bbci.co.uk/images/ic/1920x1080/p0nh9j4l.jpg.webp 1920w" src="https://ichef.bbci.co.uk/images/ic/480x270/p0nh9j4l.jpg.webp" loading="lazy" alt="Illustration of a sperm cell being injected into an egg during in vitro fertilisation (Credit: Getty Images)" class="sc-5340b511-0 hLdNfA"/></div></div></div><div data-testid="card-text-wrapper" class="sc-8a86ca4a-3 cmUYPe"><div class="sc-feaf8701-1 dzYnRP"><div class="sc-feaf8701-0 ktNWyK"><h2 data-testid="card-headline" class="sc-feaf8701-3 eQumHa">AI is finding &#x27;hidden sperm&#x27; in men deemed infertile</h2></div></div><p data-testid="card-description" class="sc-8a86ca4a-4 kgOAkr">Millions of men experience azoospermia, where they produce little to no sperm. A new AI-powered technique is giving fresh hope to couples looking to have children.</p></div></div></a></div></div><div data-testid="edinburgh-card" data-indexcard="true" class="sc-225578b-0 ezQaGx"><div data-testid="anchor-inner-wrapper"><a href="/culture/article/20260427-11-of-the-best-tv-shows-to-watch-this-may" data-testid="internal-link" class="sc-8a623a54-0 huZCWi"><div data-testid="edinburgh-article" class="sc-8a86ca4a-0 bgPRHC"><div data-testid="card-media-wrapper" class="sc-8a86ca4a-1 cazend"><div data-testid="card-media" class="sc-8a86ca4a-2 bWlUxl"><div class="sc-5340b511-1 cMIbKV"><img src="https://static.files.bbci.co.uk/bbcdotcom/web/20260427-074339-4d487e3684-web-3.2.0-4/grey-placeholder.png" class="sc-5340b511-0 gUePlo hide-when-no-script" aria-label="image unavailable"/><img sizes="(min-width: 600px) 50vw, 100vw" srcSet="https://ichef.bbci.co.uk/images/ic/160x90/p0ngv9g7.jpg.webp 160w, https://ichef.bbci.co.uk/images/ic/240x135/p0ngv9g7.jpg.webp 240w, https://ichef.bbci.co.uk/images/ic/320x180/p0ngv9g7.jpg.webp 320w, https://ichef.bbci.co.uk/images/ic/480x270/p0ngv9g7.jpg.webp 480w, https://ichef.bbci.co.uk/images/ic/640x360/p0ngv9g7.jpg.webp 640w, https://ichef.bbci.co.uk/images/ic/800x450/p0ngv9g7.jpg.webp 800w, https://ichef.bbci.co.uk/images/ic/1024x576/p0ngv9g7.jpg.webp 1024w, https://ichef.bbci.co.uk/images/ic/1376x774/p0ngv9g7.jpg.webp 1376w, https://ichef.bbci.co.uk/images/ic/1920x1080/p0ngv9g7.jpg.webp 1920w" src="https://ichef.bbci.co.uk/images/ic/480x270/p0ngv9g7.jpg.webp" loading="lazy" alt="Kelly Reilly and Cole Hauser dancing together in Dutton Ranch (Credit: Paramount)" class="sc-5340b511-0 hLdNfA"/></div></div></div><div data-testid="card-text-wrapper" class="sc-8a86ca4a-3 cmUYPe"><div class="sc-feaf8701-1 dzYnRP"><div class="sc-feaf8701-0 ktNWyK"><h2 data-testid="card-headline" class="sc-feaf8701-3 eQumHa">Dutton Ranch to Lord of the Flies: 11 of the best TV shows to watch in May</h2></div></div><p data-testid="card-description" class="sc-8a86ca4a-4 kgOAkr">From the latest Yellowstone spin-off to a new take on William Golding&#x27;s classic novel about violent schoolboys – these are the best series to watch and stream.</p></div></div></a></div></div></div></div></section><section data-testid="iowa-section-outer" data-analytics-group="true" data-analytics_group_type="iowa-10" data-analytics_group_position="4" data-analytics_group_item_count="10" data-analytics_group_link="https://www.bbc.com/audio" data-analytics_group_name="Recommended Audio" class="sc-137e23a3-1 kBGGOJ"><div data-testid="iowa-section" class="sc-137e23a3-2 bHibBM"><div class="sc-93f35dd3-2 kDYKbZ"><div class="sc-93f35dd3-1 jFZiaU"><hr data-testid="iowa-line" class="sc-93f35dd3-0 eUbJxU"/></div><div data-testid="section-title-wrapper" class="sc-93f35dd3-3 boOqBM"><div data-testid="anchor-inner-wrapper"><a href="https://www.bbc.com/audio" data-testid="external-anchor" target="_self" class="sc-8a623a54-0 huZCWi"><h2 data-testid="iowa-title" class="sc-93f35dd3-4 QbAgP">Recommended Audio<svg viewBox="0 0 32 32" width="1em" height="1em" category="arrows" icon="chevron-right" data-testid="section-title-chevron" class="sc-583246d7-0 jUqtCV"><path d="M21.6 14.3 5.5 31h6.4l14.6-15L11.9 1H5.5l16.1 16.7v-3.4z"></path></svg></h2></a></div></div></div><div data-testid="iowa-grid" class="sc-2aeeedc8-0 ktqaxd"><div class="sc-2aeeedc8-1 jIrPxd"><div data-testid="ipswich-card" data-indexcard="true" class="sc-225578b-0 ezQaGx"><div data-testid="ipswich-card" class="sc-d2483551-4 NxzKO"><div data-testid="anchor-inner-wrapper"><a href="/audio/play/w3ct8mf5" data-testid="internal-link" aria-label="The Global Story - How Ukraine won a battle with robots alone" class="sc-8a623a54-0 huZCWi"><div class="sc-d2483551