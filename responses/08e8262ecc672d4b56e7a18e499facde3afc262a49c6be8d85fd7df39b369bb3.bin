c.com/travel/worlds-table" data-testid="external-anchor" target="_self" class="sc-8a623a54-0 huZCWi"><h2 class="sc-93f35dd3-4 QbAgP">World&#x27;s Table<svg viewBox="0 0 32 32" width="1em" height="1em" category="arrows" icon="chevron-right" data-testid="section-title-chevron" class="sc-583246d7-0 jUqtCV"><path d="M21.6 14.3 5.5 31h6.4l14.6-15L11.9 1H5.5l16.1 16.7v-3.4z"></path></svg></h2></a></div></div></div><div class="sc-fa53feb6-0 bnwbbp"><div data-testid="dundee-card" data-indexcard="true" class="sc-225578b-0 ezQaGx"><div data-testid="anchor-inner-wrapper"><a href="/travel/article/20260402-which-country-can-claim-steak" data-testid="internal-link" class="sc-8a623a54-0 huZCWi"><div data-testid="dundee-article" class="sc-329e5f2b-1 kcLbQt"><div data-testid="card-image-wrapper" class="sc-329e5f2b-3 kkqTyl"><div data-testid="card-media" class="sc-329e5f2b-4 eASWcB"><div class="sc-5340b511-1 cMIbKV"><img src="https://static.files.bbci.co.uk/bbcdotcom/web/20260427-074339-4d487e3684-web-3.2.0-4/grey-placeholder.png" class="sc-5340b511-0 gUePlo hide-when-no-script" aria-label="image unavailable"/><img sizes="25vw" srcSet="https://ichef.bbci.co.uk/images/ic/160x90/p0nbcrxn.jpg.webp 160w, https://ichef.bbci.co.uk/images/ic/240x135/p0nbcrxn.jpg.webp 240w, https://ichef.bbci.co.uk/images/ic/320x180/p0nbcrxn.jpg.webp 320w, https://ichef.bbci.co.uk/images/ic/480x270/p0nbcrxn.jpg.webp 480w, https://ichef.bbci.co.uk/images/ic/640x360/p0nbcrxn.jpg.webp 640w, https://ichef.bbci.co.uk/images/ic/800x450/p0nbcrxn.jpg.webp 800w, https://ichef.bbci.co.uk/images/ic/1024x576/p0nbcrxn.jpg.webp 1024w, https://ichef.bbci.co.uk/images/ic/1376x774/p0nbcrxn.jpg.webp 1376w, https://ichef.bbci.co.uk/images/ic/1920x1080/p0nbcrxn.jpg.webp 1920w" src="https://ichef.bbci.co.uk/images/ic/480x270/p0nbcrxn.jpg.webp" loading="lazy" alt="A thick T-bone steak sits against a black background, scattered with red peppercorns, rock salt and herb (Credit: Alamy)s" class="sc-5340b511-0 hLdNfA"/></div></div></d